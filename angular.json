{
    "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
    "version": 1,
    "newProjectRoot": "projects",
    "projects": {
        "playground": {
            "projectType": "application",
            "schematics": {
                "@schematics/angular:component": {
                    "style": "scss"
                }
            },
            "root": "projects/playground",
            "sourceRoot": "projects/playground/src",
            "prefix": "app",
            "architect": {
                "build": {
                    "builder": "@angular/build:application",
                    "options": {
                        "outputPath": "dist/playground",
                        "index": "projects/playground/src/index.html",
                        "browser": "projects/playground/src/main.ts",
                        "tsConfig": "projects/playground/tsconfig.app.json",
                        "inlineStyleLanguage": "scss",
                        "stylePreprocessorOptions": {
                            "includePaths": [
                                "projects/blocks",
                                "node_modules"
                            ]
                        },
                        "assets": [
                            "projects/playground/src/favicon.ico",
                            "projects/playground/src/assets",
                            {
                                "glob": "**/*",
                                "input": "projects/playground/public"
                            },
                            {
                                "glob": "README.md",
                                "input": "documentation/modal",
                                "output": "/assets/modal-readme"
                            },
                            {
                                "glob": "README.md",
                                "input": "documentation/core",
                                "output": "/assets/blocks-core-readme"
                            },
                            {
                                "glob": "README.md",
                                "input": "documentation/toastr",
                                "output": "/assets/toastr-readme"
                            },
                            {
                                "glob": "**/*",
                                "input": "projects/playground/src/app/components/modal",
                                "output": "/assets/code-snippets"
                            },
                            {
                                "glob": "github.css",
                                "input": "./node_modules/highlight.js/styles",
                                "output": "/assets/styles"
                            },
                            {
                                "glob": "vs2015.css",
                                "input": "./node_modules/highlight.js/styles",
                                "output": "/assets/styles"
                            }
                        ],
                        "styles": [
                            "projects/playground/src/styles.scss"
                        ]
                    },
                    "configurations": {
                        "production": {
                            "budgets": [
                                {
                                    "type": "initial",
                                    "maximumWarning": "500kB",
                                    "maximumError": "5MB"
                                },
                                {
                                    "type": "anyComponentStyle",
                                    "maximumWarning": "500kB",
                                    "maximumError": "5MB"
                                }
                            ],
                            "outputHashing": "all"
                        },
                        "development": {
                            "optimization": false,
                            "extractLicenses": false,
                            "sourceMap": true
                        }
                    },
                    "defaultConfiguration": "production"
                },
                "serve": {
                    "builder": "@angular/build:dev-server",
                    "configurations": {
                        "production": {
                            "buildTarget": "playground:build:production"
                        },
                        "development": {
                            "buildTarget": "playground:build:development"
                        }
                    },
                    "defaultConfiguration": "development",
                    "options": {
                        "port": 8080
                    }
                },
                "test": {
                    "builder": "@angular/build:unit-test"
                },
                "lint": {
                    "builder": "@angular-eslint/builder:lint",
                    "options": {
                        "lintFilePatterns": [
                            "projects/playground/src/**/*.ts",
                            "projects/playground/src/**/*.html"
                        ]
                    }
                },
                "deploy": {
                    "builder": "angular-cli-ghpages:deploy"
                }
            }
        },
        "blocks": {
            "projectType": "library",
            "root": "projects/blocks",
            "sourceRoot": "projects/blocks/src",
            "prefix": "lib",
            "architect": {
                "build": {
                    "builder": "@angular/build:ng-packagr",
                    "configurations": {
                        "production": {
                            "tsConfig": "projects/blocks/tsconfig.lib.prod.json"
                        },
                        "development": {
                            "tsConfig": "projects/blocks/tsconfig.lib.json"
                        }
                    },
                    "defaultConfiguration": "production"
                },
                "test": {
                    "builder": "@angular/build:unit-test",
                    "options": {
                        "tsConfig": "projects/blocks/tsconfig.spec.json"
                    }
                },
                "lint": {
                    "builder": "@angular-eslint/builder:lint",
                    "options": {
                        "lintFilePatterns": [
                            "projects/blocks/src/**/*.ts",
                            "projects/blocks/src/**/*.html"
                        ]
                    }
                }
            }
        }
    },
    "cli": {
        "schematicCollections": [
            "angular-eslint"
        ]
    }
}