{
    "$schema": "http://json-schema.org/draft-07/schema",
    "$id": "BlocksNgAddSchema",
    "title": "Blocks Initialization Options",
    "type": "object",
    "properties": {
        "theme": {
            "type": "string",
            "description": "Select the theme for your UI.",
            "enum": [
                "purple",
                "orange"
            ],
            "x-prompt": {
                "message": "Which theme would you like to use?",
                "type": "list",
                "items": [
                    {
                        "value": "purple",
                        "label": "Purple Theme"
                    },
                    {
                        "value": "orange",
                        "label": "Orange Theme"
                    }
                ]
            },
            "default": "purple"
        }
    },
    "required": [
        "theme"
    ]
}