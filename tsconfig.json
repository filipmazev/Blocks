        "@forms/components/*": ["././projects/blocks/forms/components/*"],
        "@forms/constants/*": ["././projects/blocks/forms/constants/*"],
        "@forms/enums/*": ["././projects/blocks/forms/enums/*"],
        "@forms/helpers/*": ["././projects/blocks/forms/helpers/*"],
        "@forms/interfaces/*": ["././projects/blocks/forms/interfaces/*"],
        "@forms/services/*": ["././projects/blocks/forms/services/*"],
        "@forms/tokens/*": ["././projects/blocks/forms/tokens/*"],
        "@forms/types/*": ["././projects/blocks/forms/types/*"],
        "@forms/directives/*": ["././projects/blocks/forms/directives/*"],
        "@forms/*": ["././projects/blocks/forms/*"],
        /** Path aliases for primitives library */
        "@primitives/classes/*": ["././projects/blocks/primitives/classes/*"],
        "@primitives/components/*": ["././projects/blocks/primitives/components/*"],
        "@primitives/directives/*": ["././projects/blocks/primitives/directives/*"],
        "@primitives/enums/*": ["././projects/blocks/primitives/enums/*"],
        "@primitives/helpers/*": ["././projects/blocks/primitives/helpers/*"],
        "@primitives/interfaces/*": ["././projects/blocks/primitives/interfaces/*"],
        "@primitives/services/*": ["././projects/blocks/primitives/services/*"],
        "@primitives/tokens/*": ["././projects/blocks/primitives/tokens/*"],
        "@primitives/types/*": ["././projects/blocks/primitives/types/*"],
        "@primitives/*": ["././projects/blocks/primitives/*"],
        /** Path aliases for playground app */
        "@playground/interfaces/*": ["./././././projects/playground/src/app/shared/interfaces/*"],
        "@playground/classes/*": ["./././././projects/playground/src/app/shared/classes/*"],
        "blocks": ["./dist/blocks"],
        "@playground/types/*": ["./././././projects/playground/src/app/shared/types/*"],
        "button": ["./dist/button"],
        "icons": ["./dist/icons"],
        "@playground/components/*": ["./././././projects/playground/src/app/components/*"],
        "@playground/*": ["./././././projects/playground/src/app/*"]
    },
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "moduleResolution": "bundler",
    "importHelpers": true,
    "target": "esnext",
    "module": "esnext"
  },
  "angularCompilerOptions": {
    "enableI18nLegacyMessageIdFormat": false,
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true,
    "strictTemplates": true
  }
