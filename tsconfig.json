        "@navigation/enums/*": ["././projects/blocks/navigation/enums/*"],
        "@navigation/helpers/*": ["././projects/blocks/navigation/helpers/*"],
        "@navigation/interfaces/*": ["././projects/blocks/navigation/interfaces/*"],
        "@navigation/services/*": ["././projects/blocks/navigation/services/*"],
        "@navigation/tokens/*": ["././projects/blocks/navigation/tokens/*"],
        "@navigation/types/*": ["././projects/blocks/navigation/types/*"],
        "@navigation/directives/*": ["././projects/blocks/navigation/directives/*"],
        "@navigation/*": ["././projects/blocks/navigation/*"],
        /** Path aliases for forms library */
