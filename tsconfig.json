        "@filip.mazev/blocks/icons": ["./projects/blocks/icons/public-api.ts"],
        "@filip.mazev/blocks/modal": ["./projects/blocks/modal/public-api.ts"],
        "@filip.mazev/blocks/toastr": ["./projects/blocks/toastr/public-api.ts"],
        /** Path aliases for blocks-core library */
        "@core/constants/*": ["././projects/blocks/core/constants/*"],
        "@core/enums/*": ["././projects/blocks/core/enums/*"],
        "@core/interfaces/*": ["././projects/blocks/core/interfaces/*"],
        "@core/services/*": ["././projects/blocks/core/services/*"],
        "@core/helpers/*": ["././projects/blocks/core/helpers/*"],
        "@core/types/*": ["././projects/blocks/core/types/*"],
        "@core/tokens/*": ["././projects/blocks/core/tokens/*"],
        "@core/ui/forms/*": ["././projects/blocks/core/ui/forms/*"],
        "@core/ui/navigation/*": ["././projects/blocks/core/ui/navigation/*"],
