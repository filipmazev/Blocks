/* To learn more about Typescript configuration file: https://www.typescriptlang.org/docs/handbook/tsconfig-json.html. */
/* To learn more about Angular compiler options: https://angular.dev/reference/configs/angular-compiler-options. */
{
  "compileOnSave": false,
  "compilerOptions": {
    "outDir": "./dist/out-tsc",
    "strict": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "paths": {
    "@filip.mazev/blocks": ["./projects/blocks/src/public-api.ts"],
      "@filip.mazev/blocks/core": ["./projects/blocks/core/public-api.ts"],
      "@filip.mazev/blocks/button": ["./projects/blocks/button/public-api.ts"],
      "@filip.mazev/blocks/icons": ["./projects/blocks/icons/public-api.ts"],
      "@filip.mazev/blocks/modal": ["./projects/blocks/modal/public-api.ts"],
      "@filip.mazev/blocks/toastr": ["./projects/blocks/toastr/public-api.ts"],
      /** Path aliases for blocks-core library */
      "@core/constants/*": ["././projects/blocks/core/constants/*"],
      "@core/enums/*": ["././projects/blocks/core/enums/*"],
      "@core/interfaces/*": ["././projects/blocks/core/interfaces/*"],
      "@core/services/*": ["././projects/blocks/core/services/*"],
      "@core/helpers/*": ["././projects/blocks/core/helpers/*"],
      "@core/types/*": ["././projects/blocks/core/types/*"],
      /** Path aliases for modal library */
      "@modal/classes/*": ["././projects/blocks/modal/classes/*"],
      "@modal/components/*": ["././projects/blocks/modal/components/*"],
      "@modal/constants/*": ["././projects/blocks/modal/constants/*"],
      "@modal/directives/*": ["././projects/blocks/modal/directives/*"],
      "@modal/enums/*": ["././projects/blocks/modal/enums/*"],
      "@modal/interfaces/*": ["././projects/blocks/modal/interfaces/*"],
      "@modal/services/*": ["././projects/blocks/modal/services/*"],
      "@modal/tokens/*": ["././projects/blocks/modal/tokens/*"],
      "@modal/types/*": ["././projects/blocks/modal/types/*"],
      "@modal/*": ["././projects/blocks/modal/*"],
      /** Path aliases for toastr library */
      "@toastr/classes/*": ["././projects/blocks/toastr/classes/*"],
      "@toastr/components/*": ["././projects/blocks/toastr/components/*"],
      "@toastr/constants/*": ["././projects/blocks/toastr/constants/*"],
      "@toastr/interfaces/*": ["././projects/blocks/toastr/interfaces/*"],
      "@toastr/services/*": ["././projects/blocks/toastr/services/*"],
      "@toastr/tokens/*": ["././projects/blocks/toastr/tokens/*"],
      "@toastr/types/*": ["././projects/blocks/toastr/types/*"],
      "@toastr/*": ["././projects/blocks/toastr/*"],
      /** Path aliases for icons library */
      "@icons/classes/*": ["././projects/blocks/icons/classes/*"],
      "@icons/components/*": ["././projects/blocks/icons/components/*"],
      "@icons/constants/*": ["././projects/blocks/icons/constants/*"],
      "@icons/interfaces/*": ["././projects/blocks/icons/interfaces/*"],
      "@icons/types/*": ["././projects/blocks/icons/types/*"],
      "@icons/helpers/*": ["././projects/blocks/icons/helpers/*"],
      "@icons/*": ["././projects/blocks/icons/*"],
      /** Path aliases for button library */
      "@button/components/*": ["././projects/blocks/button/components/*"],
      "@button/types/*": ["././projects/blocks/button/types/*"],
      /** Path aliases for playground app */
      "@playground/interfaces/*": ["./././././projects/playground/src/app/shared/interfaces/*"],
      "@playground/classes/*": ["./././././projects/playground/src/app/shared/classes/*"],
      "blocks": ["./dist/blocks"],
      "@playground/types/*": ["./././././projects/playground/src/app/shared/types/*"],
      "button": ["./dist/button"],
      "icons": ["./dist/icons"],
      "@playground/components/*": ["./././././projects/playground/src/app/components/*"],
      "@playground/*": ["./././././projects/playground/src/app/*"]
    },
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "moduleResolution": "bundler",
    "importHelpers": true,
    "target": "esnext",
    "module": "esnext"
  },
  "angularCompilerOptions": {
    "enableI18nLegacyMessageIdFormat": false,
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true,
    "strictTemplates": true
  }
}
