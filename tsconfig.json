        "@toastr/services/*": ["././projects/blocks/toastr/services/*"],
        "@toastr/tokens/*": ["././projects/blocks/toastr/tokens/*"],
        "@toastr/types/*": ["././projects/blocks/toastr/types/*"],
        "@toastr/*": ["././projects/blocks/toastr/*"],
        /** Path aliases for icons library */
        "@icons/classes/*": ["././projects/blocks/icons/classes/*"],
        "@icons/components/*": ["././projects/blocks/icons/components/*"],
        "@icons/constants/*": ["././projects/blocks/icons/constants/*"],
